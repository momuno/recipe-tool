# pydantic-settings uses each field's alias= value directly as the env var name.
# The RECIPE_EXECUTOR_ prefix is NOT applied to aliased fields, so standard
# names (ANTHROPIC_API_KEY, OPENAI_API_KEY, etc.) are what the code actually reads.

# Optional for the project
#RECIPE_EXECUTOR_LOG_LEVEL=DEBUG

# Required for the project
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514

# Additional APIs
#OPENAI_API_KEY=
#GEMINI_API_KEY=

# Azure OpenAI
#AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_USE_MANAGED_IDENTITY=false
#AZURE_OPENAI_API_KEY=

#(Optional) The client ID of the specific managed identity to use.
#  If not provided, DefaultAzureCredential will be used.
#AZURE_CLIENT_ID=
